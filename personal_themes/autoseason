<script>
const e2 = new Date();
var bl2=e2.getMonth();
function seasondetector()
{
	if(bl2 >= 2 && bl2 <= 4 )
	{
		document.getElementById("sdetec").innerHTML = "beep boop it is spring.";
	}
	else if(bl2 >= 5 && bl2 <= 7 )
	{
		document.getElementById("sdetec").innerHTML = "beep boop it is summer.";
	}
	else if(bl2 >= 8 && bl2 <= 10 )
	{
		document.getElementById("sdetec").innerHTML = "beep boop it is fall.";
	}
	else if(bl2 == 11)
	{
		document.getElementById("sdetec").innerHTML = "beep boop it is winter.";
	}
	else
	{
		document.getElementById("sdetec").innerHTML = "beep boop it is winter.";
	}
}
</script>

